{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=OpenFindBearings.db"
  },
  "Authentication": {
    "Authority": "https://localhost:5001",
    "Audience": "openfindbearings-api",
    "RequireHttpsMetadata": false,
    "WebAppUrl": "https://localhost:7000"
  },
  "CacheSettings": {
    "EnableRedis": false,
    "RedisConnectionString": "localhost:6379,password=yourpassword,defaultDatabase=0",
    "DefaultExpirationMinutes": 60,
    "MemoryCacheSizeLimit": 200,
    "EnableStatistics": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://localhost:3000",
    "https://localhost:7000",
    "http://localhost:8080"
  ]
}
